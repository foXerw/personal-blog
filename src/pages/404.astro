---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---
<Base title="404 · foxerw">
  <div class="missing">
    <p class="code">404 — NOT FOUND</p>
    <h1>这一页不在这里。</h1>
    <p>它或许从未存在，或许已被收回。回到日志继续读。</p>
    <p style="margin-top:1.5rem"><a href={base}>← 回首页</a></p>
  </div>
</Base>
