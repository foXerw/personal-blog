---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description = 'foxerw 的个人博客', image, article } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site) : undefined;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="icon" href={new URL(`${import.meta.env.BASE_URL}favicon.svg`, Astro.site)} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href={new URL(`${import.meta.env.BASE_URL}rss.xml`, Astro.site)} />
    <script is:inline>
      // 无 FOUC：在首屏渲染前定主题
      const t = localStorage.getItem('theme');
      const dark = t ? t === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.dataset.theme = dark ? 'dark' : 'light';
    </script>
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-3xl px-4 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
