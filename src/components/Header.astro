---
import ThemeToggle from './ThemeToggle.tsx';
const nav = [
  { name: '文章', href: '/' },
  { name: '归档', href: '/archive' },
  { name: '标签', href: '/tags' },
  { name: '关于', href: '/about' },
  { name: '搜索', href: '/search' },
];
const base = import.meta.env.BASE_URL;
---
<header class="masthead">
  <div class="masthead-inner">
    <a href={base} class="wordmark">foxerw<span class="sep">/</span><span class="vol">field-notes</span></a>
    <nav class="nav">
      {nav.map(item => (
        <a href={`${base}${item.href.replace(/^\//, '')}`}>{item.name}</a>
      ))}
      <ThemeToggle client:load />
    </nav>
  </div>
</header>
