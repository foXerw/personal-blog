---
import type { CollectionEntry } from 'astro:content';
import { formatDate, readingTime } from '../lib/utils';

interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
const { title, date, tags, excerpt, featured } = post.data;
const base = import.meta.env.BASE_URL;
---
<li class="log-entry">
  <time class="log-date" datetime={formatDate(date, 'iso')}>{formatDate(date, 'iso')}</time>
  <div class="log-body">
    <h2 class="log-title">
      {featured && <span class="feat">※</span>}
      <a href={`${base}posts/${post.slug}`}>{title}</a>
    </h2>
    <p class="log-excerpt">{excerpt}</p>
    <p class="log-meta">
      <span>{readingTime(post.body)} 分钟</span>
      {tags.map(t => (
        <a href={`${base}tags/${t}`}>#{t}</a>
      ))}
    </p>
  </div>
</li>
